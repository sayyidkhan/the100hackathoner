---
const nav = [
  ["Journey", "/hackathons/"],
  ["Judging", "/judging/"],
  ["Principles", "/principles/"],
  ["Field Notes", "/essays/"],
  ["About", "/about/"],
  ["Contact", "/contact/"],
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="The 100 Hackathoner">
      <span>100</span>
      <strong>The 100 Hackathoner</strong>
    </a>
    <nav aria-label="Primary navigation">
      {
        nav.map(([label, href]) => (
          <a href={href} class={pathname === href ? "active" : ""}>
            {label}
          </a>
        ))
      }
    </nav>
    <a class="invite" href="/contact/">Invite Me</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: rgba(247, 245, 239, 0.9);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(220px, 0.65fr) 1fr auto;
    gap: 24px;
    align-items: center;
    min-height: 68px;
  }

  .brand {
    display: inline-flex;
    gap: 12px;
    align-items: center;
    min-width: 0;
  }

  .brand span {
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 2px solid var(--red);
    border-radius: 3px;
    color: var(--red);
    font-size: 0.78rem;
    font-weight: 950;
    line-height: 1;
  }

  .brand strong {
    overflow: hidden;
    color: var(--ink);
    font-size: 0.95rem;
    font-weight: 900;
    letter-spacing: -0.01em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 17px;
    justify-content: center;
  }

  nav a,
  .invite {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 850;
  }

  nav a {
    position: relative;
  }

  nav a::after {
    position: absolute;
    right: 0;
    bottom: 1px;
    left: 0;
    height: 2px;
    content: "";
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 160ms ease;
  }

  nav a:hover::after,
  nav a.active::after {
    transform: scaleX(1);
  }

  .invite {
    justify-content: center;
    min-width: 92px;
    padding: 0 13px;
    border: 1px solid var(--black);
    border-radius: 4px;
    background: var(--black);
    color: white;
  }

  @media (max-width: 860px) {
    .header-inner {
      grid-template-columns: 1fr auto;
      gap: 12px;
      padding: 12px 0;
    }

    nav {
      grid-column: 1 / -1;
      flex-wrap: nowrap;
      justify-content: flex-start;
      order: 3;
      gap: 16px;
      overflow-x: auto;
      padding-bottom: 2px;
    }
  }

  @media (max-width: 480px) {
    .brand strong {
      max-width: 180px;
    }

    nav a {
      font-size: 0.73rem;
    }
  }
</style>

---
interface Item {
  slug: string;
  data: {
    number: number;
    title: string;
    project: string;
    event: string;
    lesson: string;
    stack: string[];
  };
}

interface Props {
  items: Item[];
  limit?: number;
}

const visibleItems = Astro.props.limit
  ? Astro.props.items.slice(0, Astro.props.limit)
  : Astro.props.items;
---

<div class="builds">
  {
    visibleItems.map((item) => (
      <article>
        <a href={`/hackathons/${item.slug}/`}>
          <span class="meta">Hackathon #{String(item.data.number).padStart(3, "0")}</span>
          <h3>{item.data.project}</h3>
          <p>{item.data.lesson}</p>
          <ul aria-label={`${item.data.project} stack`}>
            {item.data.stack.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        </a>
      </article>
    ))
  }
</div>

<style>
  .builds {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  article {
    min-height: 260px;
    border: 1px solid var(--line);
    background: var(--surface);
  }

  a {
    display: flex;
    height: 100%;
    flex-direction: column;
    padding: 22px;
  }

  h3 {
    margin: 42px 0 12px;
    color: var(--ink);
    font-size: clamp(1.45rem, 2vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: auto 0 0;
    padding: 28px 0 0;
    list-style: none;
  }

  li {
    border-top: 2px solid var(--line);
    color: var(--faint);
    font-size: 0.76rem;
    font-weight: 900;
    padding-top: 7px;
  }

  @media (max-width: 900px) {
    .builds {
      grid-template-columns: 1fr;
    }
  }
</style>

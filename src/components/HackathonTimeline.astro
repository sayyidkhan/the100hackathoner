---
interface Item {
  slug: string;
  data: {
    number: number;
    title: string;
    event: string;
    result: string;
    lesson: string;
    date: string;
  };
}

interface Props {
  items: Item[];
  limit?: number;
}

const visibleItems = Astro.props.limit
  ? Astro.props.items.slice(0, Astro.props.limit)
  : Astro.props.items;
---

<div class="timeline">
  {
    visibleItems.map((item) => (
      <article class="timeline-item">
        <a href={`/hackathons/${item.slug}/`}>
          <span class="number">#{String(item.data.number).padStart(3, "0")}</span>
          <time datetime={item.data.date}>{item.data.date}</time>
          <div>
            <p class="meta">{item.data.event}</p>
            <h3>{item.data.title}</h3>
            <p>{item.data.lesson}</p>
          </div>
          <strong>{item.data.result}</strong>
        </a>
      </article>
    ))
  }
</div>

<style>
  .timeline {
    border-top: 1px solid var(--line-strong);
  }

  .timeline-item a {
    display: grid;
    grid-template-columns: 96px 128px minmax(0, 1fr) 150px;
    gap: 22px;
    align-items: start;
    padding: 24px 0;
    border-bottom: 1px solid var(--line);
  }

  .number {
    color: var(--red);
    font-size: 1rem;
    font-weight: 950;
    letter-spacing: -0.03em;
  }

  time {
    color: var(--faint);
    font-size: 0.82rem;
    font-weight: 850;
  }

  h3 {
    margin: 5px 0 9px;
    color: var(--ink);
    font-size: clamp(1.45rem, 3vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  strong {
    justify-self: end;
    width: fit-content;
    padding: 6px 9px;
    background: rgba(31, 157, 85, 0.12);
    color: #116437;
    font-size: 0.74rem;
    font-weight: 900;
  }

  @media (max-width: 860px) {
    .timeline-item a {
      grid-template-columns: 84px 1fr;
      gap: 10px 18px;
    }

    time,
    strong {
      justify-self: start;
    }
  }

  @media (max-width: 560px) {
    .timeline-item a {
      grid-template-columns: 1fr;
    }
  }
</style>

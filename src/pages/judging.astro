---
import { getCollection } from "astro:content";
import PageShell from "../components/PageShell.astro";

const entries = (await getCollection("judging"))
  .filter((entry) => !entry.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );
---

<PageShell title="Judging Log | The 100 Hackathoner">
  <section class="archive-hero container">
    <h1>Judging Log</h1>
    <p>
      The other side of the table: what strong teams do, where demos fail, how
      criteria shape outcomes, and what judging teaches me as a builder.
    </p>
  </section>

  <section class="section container">
    {
      entries.length ? (
        <div class="judging-list">
          {entries.map((entry) => (
            <a class="judging-row" href={`/judging/${entry.slug}/`}>
              <time datetime={entry.data.date}>{entry.data.date}</time>
              <div>
                <span class="meta">{entry.data.role} · {entry.data.domain}</span>
                <h2>{entry.data.event}</h2>
                <p>{entry.data.lesson}</p>
              </div>
              <strong>{entry.data.criteria.length} criteria</strong>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p class="meta">No Judging Entries Yet</p>
          <h2>Add the first judging log.</h2>
          <p>
            Create a Markdown file in <code>src/content/judging/</code> to
            record an event, criteria, patterns noticed, and what it taught you
            as a builder.
          </p>
        </div>
      )
    }
  </section>
</PageShell>

<style>
  .archive-hero {
    padding: 82px 0 30px;
  }

  h1 {
    max-width: 980px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(4rem, 10vw, 10rem);
    font-weight: 950;
    letter-spacing: -0.035em;
    line-height: 0.95;
  }

  .archive-hero p {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .judging-list {
    border-top: 1px solid var(--line-strong);
  }

  .judging-row {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr) 130px;
    gap: 24px;
    align-items: start;
    padding: 26px 0;
    border-bottom: 1px solid var(--line);
  }

  time {
    color: var(--faint);
    font-size: 0.82rem;
    font-weight: 850;
  }

  h2 {
    margin: 7px 0 10px;
    color: var(--ink);
    font-size: clamp(1.7rem, 3vw, 3.2rem);
    font-weight: 950;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .judging-row strong {
    justify-self: end;
    width: fit-content;
    padding: 7px 10px;
    background: rgba(19, 88, 219, 0.1);
    color: var(--blue);
    font-size: 0.76rem;
    font-weight: 900;
  }

  .empty-state {
    max-width: 720px;
    border: 1px solid var(--line-strong);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 28px;
  }

  code {
    color: var(--ink);
    font-weight: 850;
  }

  @media (max-width: 760px) {
    .judging-row {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .judging-row strong {
      justify-self: start;
    }
  }
</style>

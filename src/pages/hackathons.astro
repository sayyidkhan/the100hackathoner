---
import { getCollection } from "astro:content";
import PageShell from "../components/PageShell.astro";
import HackathonTimeline from "../components/HackathonTimeline.astro";

const hackathons = (await getCollection("hackathons")).sort(
  (a, b) => b.data.number - a.data.number,
);
---

<PageShell title="Journey Map | The 100 Hackathoner">
  <section class="archive-hero container">
    <h1>Journey Map</h1>
    <p>
      A running record of the 100-hackathon journey: what was built, what broke,
      what shipped, and the lesson that stayed after demo day.
    </p>
  </section>
  <section class="section container">
    <HackathonTimeline items={hackathons} />
  </section>
</PageShell>

<style>
  .archive-hero {
    padding: 82px 0 30px;
  }

  h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(4rem, 10vw, 10rem);
    font-weight: 950;
    letter-spacing: -0.08em;
    line-height: 0.82;
  }

  p {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.75;
  }
</style>

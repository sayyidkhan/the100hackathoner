---
import PageShell from "../components/PageShell.astro";
---

<PageShell title="Contact | The 100 Hackathoner">
  <section class="contact container">
    <div>
      <h1>Invite me into the room where builders gather.</h1>
      <p>
        Speaking, mentoring, judging, AI workshops, hackathon programming, and
        collaborations around fast prototyping, AI agents, and builder culture.
      </p>
    </div>
    <form action="mailto:hello@example.com" method="post" enctype="text/plain">
      <label>
        Name
        <input name="name" autocomplete="name" />
      </label>
      <label>
        Email
        <input name="email" type="email" autocomplete="email" />
      </label>
      <label>
        What are you planning?
        <textarea name="message" rows="6"></textarea>
      </label>
      <button class="button primary" type="submit">Start the Conversation</button>
    </form>
  </section>
</PageShell>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.65fr);
    gap: 54px;
    align-items: start;
    padding: 86px 0 112px;
  }

  h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(4rem, 9vw, 9rem);
    font-weight: 950;
    letter-spacing: -0.075em;
    line-height: 0.84;
  }

  p {
    max-width: 700px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.75;
  }

  form {
    display: grid;
    gap: 16px;
    border: 1px solid var(--line-strong);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 24px;
  }

  label {
    display: grid;
    gap: 8px;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 0;
    background: var(--bg-paper);
    color: var(--text);
    padding: 13px 12px;
  }

  textarea {
    resize: vertical;
  }

  button {
    width: 100%;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>

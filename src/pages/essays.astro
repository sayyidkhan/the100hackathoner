---
import { getCollection } from "astro:content";
import PageShell from "../components/PageShell.astro";
import EssayList from "../components/EssayList.astro";

const essays = (await getCollection("essays")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<PageShell title="Field Notes | The 100 Hackathoner">
  <section class="archive-hero container">
    <h1>Field Notes</h1>
    <p>
      Notes on repetition, identity, ambition, AI-assisted creation, failure,
      and the kind of work worth repeating.
    </p>
  </section>
  <section class="section container">
    <EssayList items={essays} />
  </section>
</PageShell>

<style>
  .archive-hero {
    padding: 82px 0 30px;
  }

  h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(4rem, 10vw, 10rem);
    font-weight: 950;
    letter-spacing: -0.08em;
    line-height: 0.82;
  }

  p {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.75;
  }
</style>

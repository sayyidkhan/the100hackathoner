---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The 100 Hackathoner",
  description = "A public record of Sayyid Khan's journey to complete 100 hackathons by building, shipping, failing, winning, and learning in public.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
